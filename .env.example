POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce
KAFKA_BOOTSTRAP_SERVERS=kafka:9092,kafka2:9092,kafka3:9092
DEBEZIUM_DB_USER=postgres
DEBEZIUM_DB_PASSWORD=postgres
PG_DSN=host=postgres port=5432 dbname=ecommerce user=postgres password=postgres
LOW_STOCK_THRESHOLD=10
# Persist low-stock alerts to lakehouse.ops.stock_alerts (set to false for console-only)
WRITE_ICEBERG_ALERTS=true
# Real-time serving layer: realtime-aggregator maintains live counters in Redis,
# order-ui's "Canlı Metrikler" tab reads them. TRENDING_WINDOW_MIN is the sliding
# window (minutes) used for the trending-products ranking.
REDIS_URL=redis://redis:6379/0
TRENDING_WINDOW_MIN=60
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
# Hard cap on the lakehouse bucket. MinIO rejects writes past this size, so a
# forgotten pipeline can never fill the host disk. Accepts mc size units (gi/ti).
LAKEHOUSE_QUOTA=20gi
# Streaming micro-batch interval. Larger = fewer Iceberg snapshots/files on MinIO.
TRIGGER_INTERVAL=30 seconds
ICEBERG_DB_USER=iceberg
ICEBERG_DB_PASSWORD=iceberg
ICEBERG_DB_NAME=iceberg
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@airflow-db/airflow
SUPERSET_SECRET_KEY=supersecretkey123
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
# DataHub (optional catalog/lineage layer — only used by docker-compose.datahub.yml)
DATAHUB_VERSION=v0.14.1
DATAHUB_SECRET=changemeplease
DATAHUB_DB_PASSWORD=datahub

# Uncomment to make every `docker compose` command include DataHub automatically,
# so it starts/stops together with the main stack (leave commented for opt-in DataHub).
# Path separator is ';' on Windows, ':' on Linux/macOS.
# COMPOSE_FILE=docker-compose.yml;docker-compose.datahub.yml